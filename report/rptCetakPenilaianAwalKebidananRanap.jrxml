                penilaian_awal_keperawatan_kebidanan_ranap.riwayat_kb_ket_komplikasi ket_komplikasi,
                penilaian_awal_keperawatan_kebidanan_ranap.riwayat_kb_kapaberhenti berhenti,
                penilaian_awal_keperawatan_kebidanan_ranap.riwayat_kb_alasanberhenti alasan,
                penilaian_awal_keperawatan_kebidanan_ranap.pengkajian_fungsi_ambulasi alat_bantu,
                penilaian_awal_keperawatan_kebidanan_ranap.pengkajian_fungsi_ket_berjalan ket_bantu,
