                penilaian_awal_keperawatan_kebidanan_ranap.penilaian_nyeri_ket_kualitas ket_quality,
                penilaian_awal_keperawatan_kebidanan_ranap.penilaian_nyeri_lokasi lokasi,
                penilaian_awal_keperawatan_kebidanan_ranap.penilaian_nyeri_menyebar menyebar,
                penilaian_awal_keperawatan_kebidanan_ranap.penilaian_nyeri_skala skala_nyeri,
                penilaian_awal_keperawatan_kebidanan_ranap.penilaian_nyeri_waktu durasi,
                penilaian_awal_keperawatan_kebidanan_ranap.penilaian_nyeri_hilang nyeri_hilang,
                penilaian_awal_keperawatan_kebidanan_ranap.penilaian_nyeri_ket_hilang ket_nyeri,
                penilaian_awal_keperawatan_kebidanan_ranap.penilaian_nyeri_diberitahukan_dokter pada_dokter,
                penilaian_awal_keperawatan_kebidanan_ranap.penilaian_nyeri_jam_diberitahukan_dokter ket_dokter,
                penilaian_awal_keperawatan_kebidanan_ranap.masalah,
                penilaian_awal_keperawatan_kebidanan_ranap.rencana tindakan,
                penilaian_awal_keperawatan_kebidanan_ranap.nip1 nip,pengkaji1.nama
                from reg_periksa
                inner join pasien on reg_periksa.no_rkm_medis=pasien.no_rkm_medis
                inner join penilaian_awal_keperawatan_kebidanan_ranap on reg_periksa.no_rawat=penilaian_awal_keperawatan_kebidanan_ranap.no_rawat
                inner join petugas pengkaji1 on penilaian_awal_keperawatan_kebidanan_ranap.nip1=pengkaji1.nip
                inner join bahasa_pasien on bahasa_pasien.id=pasien.bahasa_pasien
                inner join cacat_fisik on cacat_fisik.id=pasien.cacat_fisik
                inner join penjab on penjab.kd_pj=reg_periksa.kd_pj
	
	
	
	
	]]>
