                if(penilaian_awal_keperawatan_kebidanan_ranap.pemeriksaan_kebidanan_bb regexp '^[0-9]+(\\.[0-9]+)?$' and penilaian_awal_keperawatan_kebidanan_ranap.pemeriksaan_kebidanan_tb regexp '^[0-9]+(\\.[0-9]+)?$' and cast(penilaian_awal_keperawatan_kebidanan_ranap.pemeriksaan_kebidanan_tb as decimal(10,2))>0,round(cast(penilaian_awal_keperawatan_kebidanan_ranap.pemeriksaan_kebidanan_bb as decimal(10,2))/pow(cast(penilaian_awal_keperawatan_kebidanan_ranap.pemeriksaan_kebidanan_tb as decimal(10,2))/100,2),2),'') bmi,
                penilaian_awal_keperawatan_kebidanan_ranap.pemeriksaan_kebidanan_lila lila,
                penilaian_awal_keperawatan_kebidanan_ranap.pemeriksaan_kebidanan_tfu tfu,
