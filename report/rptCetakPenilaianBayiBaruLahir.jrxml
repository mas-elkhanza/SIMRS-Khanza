				<textElement>
					<font fontName="Tahoma" size="9.0"/>
				</textElement>
				<textFieldExpression><![CDATA["\nIV. KEADAAN BAYI SAAT LAHIR\n"+
"    BB Lahir                                               : "+($F{bblahir}==null?"-":$F{bblahir})+" gram\n"+
"    Panjang Badan                                   : "+($F{panjang_badan}==null?"-":$F{panjang_badan})+" cm\n"+
"    Lingkar Kepala                                    : "+($F{lingkar_kepala}==null?"-":$F{lingkar_kepala})+" cm\n"+
"    Lingkar Dada                                      : "+($F{lingkar_dada}==null?"-":$F{lingkar_dada})+" cm\n"+
"    Resusitasi Saat Lahir                          : "+($F{resusitasi_saat_lahir}==null?"-":$F{resusitasi_saat_lahir})+"\n"+
"    Ket. Resusitasi                                    : "+($F{keterangan_resusitasi_saat_lahir}==null?"-":$F{keterangan_resusitasi_saat_lahir})+"\n"+
"    Obat Diberikan Saat Lahir                  : "+($F{obat_diberikan_saat_lahir}==null?"-":$F{obat_diberikan_saat_lahir})+"\n"+
"    Keterangan Lainnya                            : "+($F{keterangan_lainnya_keadaan_bayi}==null?"-":$F{keterangan_lainnya_keadaan_bayi})+"\n\n"+
"V. PEMERIKSAAN FISIK\n"+
"    Kondisi Umum                                    : "+($F{kondisi_umum}==null?"-":$F{kondisi_umum})+"    Ket: "+($F{keterangan_kondisi_umum}==null?"-":$F{keterangan_kondisi_umum})+"\n"+
"    Kulit                                                      : "+($F{kulit}==null?"-":$F{kulit})+"    Ket: "+($F{keterangan_kulit}==null?"-":$F{keterangan_kulit})+"\n"+
"    Kepala                                                  : "+($F{kepala}==null?"-":$F{kepala})+"    Ket: "+($F{keterangan_kepala}==null?"-":$F{keterangan_kepala})+"\n"+
"    Leher                                                    : "+($F{leher}==null?"-":$F{leher})+"    Ket: "+($F{keterangan_leher}==null?"-":$F{keterangan_leher})+"\n"+
"    Mata                                                     : "+($F{mata}==null?"-":$F{mata})+"    Ket: "+($F{keterangan_mata}==null?"-":$F{keterangan_mata})+"\n"+
"    Hidung                                                  : "+($F{hidung}==null?"-":$F{hidung})+"    Ket: "+($F{keterangan_hidung}==null?"-":$F{keterangan_hidung})+"\n"+
"    Telinga                                                  : "+($F{telinga}==null?"-":$F{telinga})+"    Ket: "+($F{keterangan_telinga}==null?"-":$F{keterangan_telinga})+"\n"+
"    Dada                                                     : "+($F{pemeriksaan_dada}==null?"-":$F{pemeriksaan_dada})+"    Ket: "+($F{keterangan_dada}==null?"-":$F{keterangan_dada})+"\n"+
"    Paru                                                      : "+($F{paru}==null?"-":$F{paru})+"    Ket: "+($F{keterangan_paru}==null?"-":$F{keterangan_paru})+"\n"+
"    Jantung                                                 : "+($F{jantung}==null?"-":$F{jantung})+"    Ket: "+($F{keterangan_jantung}==null?"-":$F{keterangan_jantung})+"\n"+
"    Perut                                                      : "+($F{perut}==null?"-":$F{perut})+"    Ket: "+($F{keterangan_perut}==null?"-":$F{keterangan_perut})+"\n"+
"    Tali Pusat                                              : "+($F{tali_pusat}==null?"-":$F{tali_pusat})+"    Ket: "+($F{keterangan_tali_pusat}==null?"-":$F{keterangan_tali_pusat})+"\n"+
"    Alat Kelamin                                        : "+($F{alat_kelamin}==null?"-":$F{alat_kelamin})+"    Ket: "+($F{keterangan_alat_kelamin}==null?"-":$F{keterangan_alat_kelamin})+"\n"+
"    Ruas Tulang Belakang                        : "+($F{ruas_tulang_belakang}==null?"-":$F{ruas_tulang_belakang})+"    Ket: "+($F{keterangan_ruas_tulang_belakang}==null?"-":$F{keterangan_ruas_tulang_belakang})+"\n"+
"    Extrimitas                                             : "+($F{extrimitas}==null?"-":$F{extrimitas})+"    Ket: "+($F{keterangan_extrimitas}==null?"-":$F{keterangan_extrimitas})+"\n"+
"    Anus                                                      : "+($F{anus}==null?"-":$F{anus})+"    Ket: "+($F{keterangan_anus}==null?"-":$F{keterangan_anus})+"\n"+
"    Refleks                                                  : "+($F{refleks}==null?"-":$F{refleks})+"    Ket: "+($F{keterangan_refleks}==null?"-":$F{keterangan_refleks})+"\n"+
"    Denyut Femoral                                   : "+($F{denyut_femoral}==null?"-":$F{denyut_femoral})+"    Ket: "+($F{keterangan_denyut_femoral}==null?"-":$F{keterangan_denyut_femoral})+"\n"+
"    Pemeriksaan Fisik Lainnya                  : "+($F{pemeriksaan_fisik_lainnya}==null?"-":$F{pemeriksaan_fisik_lainnya})+"\n"+
"    Pemeriksaan Penunjang                     : "+($F{pemeriksaan_penunjang}==null?"-":$F{pemeriksaan_penunjang})+"\n\n"+
"VI. DIAGNOSA DAN TATALAKSANA\n"+
"    Diagnosa                                              : "+($F{diagnosa}==null?"-":$F{diagnosa})+"\n"+
"    Tatalaksana                                          : "+($F{tatalaksana}==null?"-":$F{tatalaksana})
				]]></textFieldExpression>
			</textField>
