					<font fontName="Tahoma" size="9.0"/>
				</textElement>
				<textFieldExpression><![CDATA["I. RIWAYAT MATERNAL\n"+
"    Penyakit Diderita Ibu                          : "+($F{penyakit_diderita_ibu}==null?"-":$F{penyakit_diderita_ibu})+"\n"+
"    Ket. Penyakit Ibu                                 : "+($F{keterangan_penyakit_diderita_ibu}==null?"-":$F{keterangan_penyakit_diderita_ibu})+"\n"+
"    Obat Dikonsumsi Selama Kehamilan  : "+($F{obat_dikonsumsi_selama_kehamilan}==null?"-":$F{obat_dikonsumsi_selama_kehamilan})+"\n"+
"    Perawatan Antenatal                           : "+($F{perawatan_antenatal}==null?"-":$F{perawatan_antenatal})+"\n"+
"    Ket. Perawatan Antenatal                   : "+($F{keterangan_perawatan_antenatal}==null?"-":$F{keterangan_perawatan_antenatal})+"\n"+
"    Terdaftar Ekohort                                : "+($F{terdaftar_ekohort}==null?"-":$F{terdaftar_ekohort})+"\n"+
"    Ket. Terdaftar Ekohort                        : "+($F{keterangan_terdaftar_ekohort}==null?"-":$F{keterangan_terdaftar_ekohort})+"\n"+
"    Penyulit Kehamilan                             : "+($F{penyulit_kehamilan}==null?"-":$F{penyulit_kehamilan})+"\n"+
"    Ket. Penyulit Kehamilan                     : "+($F{keterangan_penyulit_kehamilan}==null?"-":$F{keterangan_penyulit_kehamilan})+"\n"+
"    Alergi                                                    : "+($F{alergi}==null?"-":$F{alergi})+"\n"+
"    Keterangan Lainnya                            : "+($F{keterangan_lainnya_riwayat_maternal}==null?"-":$F{keterangan_lainnya_riwayat_maternal})+"\n\n"+
"II. RIWAYAT PERSALINAN\n"+
"    Umur Kehamilan                                 : "+($F{umur_kehamilan}==null?"-":$F{umur_kehamilan})+"\n"+
"    Kehamilan                                            : "+($F{kehamilan}==null?"-":$F{kehamilan})+"\n"+
"    Ket. Kehamilan                                    : "+($F{keterangan_kehamilan}==null?"-":$F{keterangan_kehamilan})+"\n"+
"    Urutan Kehamilan                               : "+($F{urutan_kehamilan}==null?"-":$F{urutan_kehamilan})+"\n"+
"    Ketuban Pecah                                    : "+($F{jam_ketuban_pecah}==null?"-":$F{jam_ketuban_pecah})+" jam "+($F{menit_ketuban_pecah}==null?"-":$F{menit_ketuban_pecah})+" menit\n"+
"    Jumlah Air Ketuban                             : "+($F{jumlah_air_ketuban}==null?"-":$F{jumlah_air_ketuban})+"\n"+
"    Warna Air Ketuban                              : "+($F{warna_air_ketuban}==null?"-":$F{warna_air_ketuban})+"\n"+
"    Bau Air Ketuban                                  : "+($F{bau_air_ketuban}==null?"-":$F{bau_air_ketuban})+"\n"+
"    Letak Bayi                                            : "+($F{letak_bayi}==null?"-":$F{letak_bayi})+"\n"+
"    Macam Persalinan                               : "+($F{macam_persalinan}==null?"-":$F{macam_persalinan})+"\n"+
"    Ket. Macam Persalinan                       : "+($F{keterangan_macam_persalinan}==null?"-":$F{keterangan_macam_persalinan})+"\n"+
"    Indikasi Persalinan Operatif               : "+($F{indikasi_persalinan_operatif}==null?"-":$F{indikasi_persalinan_operatif})+"\n"+
"    Ket. Indikasi Persalinan Operatif       : "+($F{keterangan_indikasi_persalinan_operatif}==null?"-":$F{keterangan_indikasi_persalinan_operatif})+"\n"+
"    Lama Gawat Janin                              : "+($F{lama_gawat_janin}==null?"-":$F{lama_gawat_janin})+"\n"+
"    Obat Selama Persalinan                     : "+($F{obat_selama_persalinan}==null?"-":$F{obat_selama_persalinan})+"\n"+
"    Berat Placenta                                    : "+($F{berat_placenta}==null?"-":$F{berat_placenta})+"\n"+
"    Kelainan Placenta                              : "+($F{kelainan_placenta}==null?"-":$F{kelainan_placenta})+"\n"+
"    Keterangan Lainnya                            : "+($F{keterangan_lainnya_riwayat_persalinan}==null?"-":$F{keterangan_lainnya_riwayat_persalinan})
				]]></textFieldExpression>
