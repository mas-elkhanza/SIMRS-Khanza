{"pcrapersyaratandipenuhi":[{"Kode":"PH001","Nama":"Jenis dan lokasi barrier / partisi penghalang debu sudah direncanakan dan disetujui K3RS"},{"Kode":"PH002","Nama":"Minimal 2 (dua) jalur keluar aman sudah diidentifikasi dan dipastikan tidak akan terhalang selama konstruksi"},{"Kode":"PH003","Nama":"Rencana kompensasi sistem deteksi kebakaran sudah dikomunikasikan ke IPSRS (misal: penutup detektor sementara selama jam kerja)"},{"Kode":"PH004","Nama":"Jumlah dan lokasi penempatan APAR di area proyek sudah direncanakan dan disetujui"},{"Kode":"PH005","Nama":"Jadwal sosialisasi kode emergensi RS kepada seluruh pekerja proyek sudah ditetapkan sebelum hari pertama kerja"},{"Kode":"PH006","Nama":"Lokasi penyimpanan B3 yang sesuai MSDS sudah diidentifikasi dan disetujui, terpisah dari area pasien"},{"Kode":"PH007","Nama":"Jenis APD yang diperlukan sesuai tipe pekerjaan sudah ditentukan dan kontraktor sudah menyanggupi penyediaannya"},{"Kode":"PH008","Nama":"Jam kerja konstruksi sudah dikoordinasikan dan disetujui manajemen RS agar tidak mengganggu ketenangan pasien"},{"Kode":"PH009","Nama":"Jalur mobilisasi material dan pembuangan debris sudah ditetapkan dan tidak melewati area kritis pasien"},{"Kode":"PH010","Nama":"Rencana pemantauan kualitas udara & debu harian sudah disiapkan (wajib untuk Kelas III dan IV)"},{"Kode":"PH011","Nama":"Mekanisme pembersihan harian area proyek sebelum pekerja meninggalkan lokasi sudah disepakati dalam kontrak"},{"Kode":"PH012","Nama":"Kontraktor sudah memahami, menyetujui, dan menandatangani surat perjanjian kepatuhan K3RS sebelum mobilisasi"},{"Kode":"PH013","Nama":"Izin kerja konstruksi (work permit) dari manajemen RS sudah diterbitkan"}]}